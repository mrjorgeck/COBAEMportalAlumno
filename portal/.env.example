APP_NAME="Portal Nuevo Ingreso COBAEM Ario"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

# Local: crear BD cobaem_portal_dev en MariaDB/MySQL
# Producción: u132762550_COBAEM (credenciales SOLO en el .env del servidor)
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cobaem_portal_dev
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
# Produccion HTTPS:
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
# PORTAL_AVISO_PRIVACIDAD_FECHA_PUBLICACION="pendiente de fijar por el plantel"

# Hostinger compartido: sin Redis. Colas en BD procesadas por cron.
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="portal@registrocobaemario.ariocentro.com"
MAIL_FROM_NAME="${APP_NAME}"

# Servicio OMR externo (Fase 4)
OMR_SERVICE_URL=
OMR_SERVICE_KEY=

VITE_APP_NAME="${APP_NAME}"
